# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_NUM_PARTITIONS=6
KAFKA_REPLICATION_FACTOR=1

# Flink
FLINK_JOBMANAGER_HOST=localhost
FLINK_JOBMANAGER_PORT=8081
FLINK_PARALLELISM=2

# MinIO (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=agentflow-lake

# Iceberg
ICEBERG_CATALOG_URI=thrift://localhost:9083
ICEBERG_WAREHOUSE=s3://agentflow-lake/warehouse

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
AGENTFLOW_API_KEYS_FILE=config/api_keys.yaml
AGENTFLOW_ADMIN_KEY=change-me
AGENTFLOW_RATE_LIMIT_RPM=120
# CORS: comma-separated list of allowed origins
# Use * for development only (never in production)
AGENTFLOW_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
OTEL_SERVICE_NAME=agentflow-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# Quality
FRESHNESS_SLA_SECONDS=30
QUALITY_MIN_SCORE=0.95
