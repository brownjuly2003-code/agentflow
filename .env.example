# AgentFlow example environment.
# Copy to .env and replace placeholder values before using outside local development.

# Local API / demo
DUCKDB_PATH=./agentflow_demo.duckdb
AGENTFLOW_USAGE_DB_PATH=./agentflow_api.duckdb
AGENTFLOW_DEMO_MODE=false
AGENTFLOW_SEED_ON_BOOT=false
AGENTFLOW_API_KEYS_FILE=config/api_keys.yaml
AGENTFLOW_ADMIN_KEY=<replace-with-strong-random>
AGENTFLOW_RATE_LIMIT_RPM=120
AGENTFLOW_ROTATION_GRACE_PERIOD_SECONDS=86400
AGENTFLOW_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
AGENTFLOW_HEALTH_CACHE_TTL_SECONDS=5
CACHE_TTL_SECONDS=30
REDIS_URL=redis://localhost:6379

# API process
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
SERVING_BACKEND=duckdb
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=agentflow
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Kafka / Flink
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_NUM_PARTITIONS=6
KAFKA_REPLICATION_FACTOR=1
FLINK_JOBMANAGER_HOST=localhost
FLINK_JOBMANAGER_PORT=8081
FLINK_PARALLELISM=2

# Iceberg / object storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=<replace-with-access-key>
S3_SECRET_KEY=<replace-with-secret-key>
S3_BUCKET=agentflow-lake
ICEBERG_CATALOG_URI=thrift://localhost:9083
ICEBERG_WAREHOUSE=s3://agentflow-lake/warehouse

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=<replace-with-strong-random>
OTEL_SERVICE_NAME=agentflow-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# Quality
FRESHNESS_SLA_SECONDS=30
QUALITY_MIN_SCORE=0.95
