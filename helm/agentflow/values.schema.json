{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "nameOverride",
    "fullnameOverride",
    "replicaCount",
    "image",
    "imagePullSecrets",
    "serviceAccount",
    "podAnnotations",
    "podLabels",
    "service",
    "ingress",
    "autoscaling",
    "persistence",
    "resources",
    "probes",
    "config",
    "secrets",
    "affinity",
    "nodeSelector",
    "tolerations",
    "extraEnv",
    "podSecurityContext",
    "containerSecurityContext",
    "tmpVolume",
    "podDisruptionBudget",
    "networkPolicy"
  ],
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "tag",
        "pullPolicy"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "create",
        "annotations",
        "name"
      ],
      "properties": {
        "create": {
          "type": "boolean"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "name": {
          "type": "string"
        }
      }
    },
    "podAnnotations": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "podLabels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "port",
        "annotations"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer",
            "ExternalName"
          ]
        },
        "port": {
          "type": "integer",
          "minimum": 1
        },
        "nodePort": {
          "type": "integer",
          "minimum": 1
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "className",
        "annotations",
        "hosts",
        "tls"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "host",
              "paths"
            ],
            "properties": {
              "host": {
                "type": "string",
                "minLength": 1
              },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "path",
                    "pathType"
                  ],
                  "properties": {
                    "path": {
                      "type": "string",
                      "minLength": 1
                    },
                    "pathType": {
                      "type": "string",
                      "enum": [
                        "Exact",
                        "ImplementationSpecific",
                        "Prefix"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "tls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "hosts": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "secretName": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "minReplicas",
        "maxReplicas",
        "targetCPUUtilizationPercentage"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "maxReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "persistence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "accessModes",
        "size",
        "storageClassName",
        "mountPath"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "accessModes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "size": {
          "type": "string",
          "minLength": 1
        },
        "storageClassName": {
          "type": "string"
        },
        "mountPath": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requests",
        "limits"
      ],
      "properties": {
        "requests": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "properties": {
            "cpu": {
              "type": "string",
              "minLength": 1
            },
            "memory": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "properties": {
            "cpu": {
              "type": "string",
              "minLength": 1
            },
            "memory": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "probes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "readiness",
        "liveness"
      ],
      "properties": {
        "readiness": {
          "$ref": "#/definitions/probe"
        },
        "liveness": {
          "$ref": "#/definitions/probe"
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "duckdbPath",
        "usageDbPath",
        "apiKeysPath",
        "tenantsPath",
        "sloPath",
        "piiFieldsPath",
        "securityPath",
        "apiVersionsPath",
        "contractsDir",
        "rateLimitRpm",
        "cacheTtlSeconds",
        "corsOrigins",
        "redisUrl",
        "otlpEndpoint",
        "otlpServiceName",
        "tenants",
        "slo",
        "piiFields",
        "security",
        "apiVersions"
      ],
      "properties": {
        "duckdbPath": {
          "type": "string",
          "minLength": 1
        },
        "usageDbPath": {
          "type": "string",
          "minLength": 1
        },
        "apiKeysPath": {
          "type": "string",
          "minLength": 1
        },
        "tenantsPath": {
          "type": "string",
          "minLength": 1
        },
        "sloPath": {
          "type": "string",
          "minLength": 1
        },
        "piiFieldsPath": {
          "type": "string",
          "minLength": 1
        },
        "securityPath": {
          "type": "string",
          "minLength": 1
        },
        "apiVersionsPath": {
          "type": "string",
          "minLength": 1
        },
        "contractsDir": {
          "type": "string",
          "minLength": 1
        },
        "rateLimitRpm": {
          "type": "integer",
          "minimum": 1
        },
        "cacheTtlSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "corsOrigins": {
          "type": "string"
        },
        "redisUrl": {
          "type": "string"
        },
        "otlpEndpoint": {
          "type": "string"
        },
        "otlpServiceName": {
          "type": "string",
          "minLength": 1
        },
        "tenants": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tenants"
          ],
          "properties": {
            "tenants": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "display_name",
                  "kafka_topic_prefix",
                  "duckdb_schema",
                  "max_events_per_day",
                  "max_api_keys"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "display_name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "kafka_topic_prefix": {
                    "type": "string",
                    "minLength": 1
                  },
                  "duckdb_schema": {
                    "type": "string",
                    "minLength": 1
                  },
                  "max_events_per_day": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "max_api_keys": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "allowed_entity_types": {
                    "$ref": "#/definitions/stringArrayOrNull"
                  }
                }
              }
            }
          }
        },
        "slo": {
          "type": "string",
          "minLength": 1
        },
        "piiFields": {
          "type": "string",
          "minLength": 1
        },
        "security": {
          "type": "string",
          "minLength": 1
        },
        "apiVersions": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "secrets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adminKey",
        "apiKeys"
      ],
      "properties": {
        "adminKey": {
          "type": "string"
        },
        "apiKeys": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "keys"
          ],
          "properties": {
            "keys": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "key_id",
                  "name",
                  "tenant",
                  "rate_limit_rpm",
                  "created_at"
                ],
                "properties": {
                  "key_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "key": {
                    "type": "string",
                    "minLength": 1
                  },
                  "key_hash": {
                    "type": "string",
                    "minLength": 1
                  },
                  "previous_key_hash": {
                    "type": "string",
                    "minLength": 1
                  },
                  "previous_key_active_until": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "tenant": {
                    "type": "string",
                    "minLength": 1
                  },
                  "rate_limit_rpm": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "allowed_entity_types": {
                    "$ref": "#/definitions/stringArrayOrNull"
                  },
                  "created_at": {
                    "type": "string",
                    "format": "date"
                  }
                },
                "anyOf": [
                  {
                    "required": [
                      "key"
                    ]
                  },
                  {
                    "required": [
                      "key_hash"
                    ]
                  }
                ]
              }
            }
          }
        }
      }
    },
    "affinity": {
      "type": "object"
    },
    "nodeSelector": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "tolerations": {
      "type": "array"
    },
    "extraEnv": {
      "type": "array"
    },
    "podSecurityContext": {
      "type": "object"
    },
    "containerSecurityContext": {
      "type": "object"
    },
    "tmpVolume": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "sizeLimit": {
          "type": "string"
        }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "minAvailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string" }
          ]
        },
        "maxUnavailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string" }
          ]
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "ingressFromNamespaces": {
          "type": "array"
        },
        "egressPorts": {
          "type": "object"
        }
      }
    }
  },
  "definitions": {
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "initialDelaySeconds",
        "periodSeconds",
        "timeoutSeconds",
        "failureThreshold"
      ],
      "properties": {
        "initialDelaySeconds": {
          "type": "integer",
          "minimum": 1
        },
        "periodSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "failureThreshold": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "stringArrayOrNull": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
