{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "AgentFlow API surface observability. Uses agentflow_http_requests_total (src/serving/api/middleware/metrics.py) and agentflow_auth_failures_total (src/serving/api/auth/middleware.py + require_admin_key), both scraped from /metrics mounted in src/serving/api/main.py. The 5xx-rate-by-route + HTTP-request-rate-by-status panels back docs/runbooks/api-5xx-spike.md (Detection step 1). The auth-failures-by-reason panel backs docs/runbooks/auth-401-spike.md (Detection step 1, reason label matches the documented vocabulary). Requests rejected by an early middleware (auth 401/429/503, demo_mode_guard) report as route=<unmatched> on agentflow_http_requests_total because the FastAPI router only populates request.scope['route'] after call_next reaches it — route-level detail for auth-rejected traffic is on agentflow_auth_failures_total instead.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "5xx response rate per route template, rolling 5m. Spikes here are the primary signal for docs/runbooks/api-5xx-spike.md.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(agentflow_http_requests_total{status=~\"5..\"}[5m])) by (route)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "5xx response rate by route (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Authentication failure rate split by reason. Reason vocabulary matches docs/runbooks/auth-401-spike.md Detection step 1: missing_key, invalid_key, key_file_empty, rate_limited, admin_invalid, admin_unconfigured.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 20,
            "showPoints": "never",
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(agentflow_auth_failures_total[5m])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "title": "Auth failures by reason (req/s, stacked)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "4xx response rate per route template (excluding 401/429 which auth surfaces as <unmatched>). 403 here usually means PermissionDeniedError (allowed_entity_types).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(agentflow_http_requests_total{status=~\"4..\",status!=\"401\",status!=\"429\"}[5m])) by (route, status)",
          "legendFormat": "{{status}} {{route}}",
          "refId": "A"
        }
      ],
      "title": "4xx response rate by route + status (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Overall request rate split by HTTP status class. Useful for the 'fan-out vs single-route' triage question in api-5xx-spike.md.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 20,
            "showPoints": "never",
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(agentflow_http_requests_total[5m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Request rate by status class (req/s, stacked)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Cumulative auth failures over the dashboard time range, per reason. Helps confirm that a spike on the auth-failures-by-reason panel is broad-based and not a single client burst.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 18 },
      "id": 5,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": false,
        "valueMode": "color"
      },
      "targets": [
        {
          "expr": "sum(increase(agentflow_auth_failures_total[$__range])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "title": "Auth failures over selected range, by reason (cumulative)",
      "type": "bargauge"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["agentflow", "api", "auth", "http"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "AgentFlow — API Health",
  "uid": "agentflow-api-health",
  "version": 1,
  "weekStart": ""
}
