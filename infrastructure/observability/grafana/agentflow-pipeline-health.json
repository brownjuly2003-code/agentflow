{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "AgentFlow ingestion + CDC pipeline observability. Uses metrics exported by src/quality/monitors/freshness_monitor.py and src/quality/monitors/metrics_collector.py (scraped by Prometheus at the /metrics endpoint mounted in src/serving/api/main.py). The Pipeline Latency / SLA Compliance / Consumer Lag panels back the cdc-lag.md runbook directly. HTTP-level panels for api-5xx-spike.md and auth-401-spike.md live in the sibling dashboard agentflow-api-health.json — both counters (agentflow_http_requests_total + agentflow_auth_failures_total) are now exported by src/serving/api/middleware/metrics.py and src/serving/api/auth/middleware.py respectively.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "End-to-end pipeline latency from Kafka source to Iceberg/serving. Histogram bucketed at 0.1/0.5/1/2/5/10/30/60s. SLO line at FRESHNESS_SLA_SECONDS env var (default 30s).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 30 },
              { "color": "red", "value": 60 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(agentflow_pipeline_latency_seconds_bucket[5m])) by (le, topic))",
          "legendFormat": "p50 {{topic}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(agentflow_pipeline_latency_seconds_bucket[5m])) by (le, topic))",
          "legendFormat": "p95 {{topic}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(agentflow_pipeline_latency_seconds_bucket[5m])) by (le, topic))",
          "legendFormat": "p99 {{topic}}",
          "refId": "C"
        }
      ],
      "title": "Pipeline latency (event → serving) by topic",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "SLA compliance ratio per topic from FreshnessMonitor (rolling 1000-event window). 1.0 = all events within FRESHNESS_SLA_SECONDS, 0.0 = none.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "max": 1,
          "min": 0,
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": false,
        "valueMode": "color"
      },
      "targets": [
        {
          "expr": "agentflow_sla_compliance_ratio",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "title": "SLA compliance ratio by topic (rolling 1k events)",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Kafka consumer lag in records per partition. Spikes here precede the latency p99 climb on the panel above.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "agentflow_consumer_lag",
          "legendFormat": "{{group_id}} / {{topic}} / partition={{partition}}",
          "refId": "A"
        }
      ],
      "title": "Kafka consumer lag by partition",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Per-component pipeline health: 1.0 = healthy, 0.5 = degraded, 0.0 = unhealthy. Drives the health endpoint in src/serving/api/main.py.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            { "options": { "0": { "color": "red", "text": "unhealthy" } }, "type": "value" },
            { "options": { "0.5": { "color": "orange", "text": "degraded" } }, "type": "value" },
            { "options": { "1": { "color": "green", "text": "healthy" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.5 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "agentflow_pipeline_health",
          "legendFormat": "{{component}}",
          "refId": "A"
        }
      ],
      "title": "Component health",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Total events processed per topic since FreshnessMonitor started. Increasing slope = events flowing. Flat = stalled ingestion (cross-check with consumer lag).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "agentflow_freshness_events_total",
          "legendFormat": "{{topic}}",
          "refId": "A"
        }
      ],
      "title": "Events processed by topic (running total)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["agentflow", "ingestion", "cdc", "pipeline"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "AgentFlow — Pipeline Health",
  "uid": "agentflow-pipeline-health",
  "version": 1,
  "weekStart": ""
}
