{
  "title": "AgentFlow Ops Agent Journey",
  "uid": "agentflow-ops",
  "tags": ["agentflow", "ops", "journey"],
  "timezone": "utc",
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Pipeline Health Timeline",
      "description": "Continuous component health stream from the HealthCollector.",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "agentflow_pipeline_health",
          "legendFormat": "{{ component }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 2,
      "title": "Kafka Consumer Lag",
      "description": "Appears when consumer lag collection is enabled for Kafka groups.",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "max by (group_id, topic) (agentflow_consumer_lag)",
          "legendFormat": "{{ group_id }} / {{ topic }}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Pipeline Latency (p50 / p95 / p99)",
      "description": "Core latency SLO proxy from the freshness monitor histogram.",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(agentflow_pipeline_latency_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(agentflow_pipeline_latency_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(agentflow_pipeline_latency_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 4,
      "title": "Dead Letter Rate (24h)",
      "description": "Expects counters agentflow_dead_letter_events_total and agentflow_ingested_events_total to expose the dead-letter ratio in Prometheus.",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum(increase(agentflow_dead_letter_events_total[24h])) / clamp_min(sum(increase(agentflow_ingested_events_total[24h])), 1)",
          "legendFormat": "dead letter rate"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 0.001},
              {"color": "red", "value": 0.01}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Freshness SLO Compliance",
      "description": "Live freshness SLO ratio already exported to Prometheus.",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
      "targets": [
        {
          "expr": "min(agentflow_sla_compliance_ratio)",
          "legendFormat": "freshness"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 0.95},
              {"color": "green", "value": 0.99}
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "SLO Error Budget Remaining",
      "description": "Backs the /v1/slo journey. Expects a Prometheus exporter that mirrors /v1/slo as agentflow_slo_error_budget_remaining{objective=...}.",
      "type": "bargauge",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "expr": "agentflow_slo_error_budget_remaining{objective=~\"api_latency_p95|data_freshness|error_rate\"}",
          "legendFormat": "{{ objective }}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 0.2},
              {"color": "green", "value": 0.5}
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Alert Triggers (24h)",
      "description": "Expects Prometheus counter agentflow_alert_triggers_total{alert_name=...}. Mirrors recent alert history.",
      "type": "barchart",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "topk(10, sum by (alert_name) (increase(agentflow_alert_triggers_total[24h])))",
          "legendFormat": "{{ alert_name }}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 8,
      "title": "Component Health Snapshot",
      "description": "Instant table view for escalation triage.",
      "type": "table",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 18},
      "targets": [
        {
          "expr": "agentflow_pipeline_health",
          "legendFormat": "{{ component }}",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
