{
  "dashboard": {
    "title": "AgentFlow Pipeline Health",
    "uid": "agentflow-pipeline",
    "tags": ["agentflow", "pipeline"],
    "timezone": "utc",
    "refresh": "10s",
    "panels": [
      {
        "title": "Pipeline Status",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "min(agentflow_pipeline_health)",
            "legendFormat": "Overall"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {"1": {"text": "HEALTHY", "color": "green"}}},
              {"type": "value", "options": {"0.5": {"text": "DEGRADED", "color": "yellow"}}},
              {"type": "value", "options": {"0": {"text": "UNHEALTHY", "color": "red"}}}
            ]
          }
        }
      },
      {
        "title": "SLA Compliance",
        "type": "gauge",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "agentflow_sla_compliance_ratio",
            "legendFormat": "{{ topic }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 0.9, "color": "yellow"},
                {"value": 0.95, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "title": "Events/sec by Topic",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "rate(agentflow_freshness_events_total[1m])",
            "legendFormat": "{{ topic }}"
          }
        ]
      },
      {
        "title": "Pipeline Latency (p50 / p99)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "histogram_quantile(0.5, rate(agentflow_pipeline_latency_seconds_bucket[5m]))",
            "legendFormat": "p50 {{ topic }}"
          },
          {
            "expr": "histogram_quantile(0.99, rate(agentflow_pipeline_latency_seconds_bucket[5m]))",
            "legendFormat": "p99 {{ topic }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        }
      },
      {
        "title": "Latency Distribution",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "rate(agentflow_pipeline_latency_seconds_bucket[5m])",
            "legendFormat": "{{ le }}"
          }
        ]
      },
      {
        "title": "Component Health",
        "type": "table",
        "gridPos": {"h": 6, "w": 12, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "agentflow_pipeline_health",
            "legendFormat": "{{ component }}",
            "format": "table",
            "instant": true
          }
        ]
      }
    ]
  }
}
