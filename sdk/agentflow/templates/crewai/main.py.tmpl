from crewai import Agent, Crew, Task

from agentflow_integrations.crewai import get_agentflow_tools


def main() -> None:
    tools = get_agentflow_tools("__BASE_URL__", api_key="__API_KEY__")

    analyst = Agent(
        role="Operations Analyst",
        goal="Answer operational questions with live data from AgentFlow.",
        backstory="You help teams inspect orders and metrics before incidents escalate.",
        tools=tools,
        verbose=True,
    )

    task = Task(
        description="Explain the current status of order ORD-001 and the latest revenue metric.",
        expected_output="A concise operational summary with order and metric details.",
        agent=analyst,
    )

    crew = Crew(agents=[analyst], tasks=[task], verbose=True)
    print(crew.kickoff())


if __name__ == "__main__":
    main()
